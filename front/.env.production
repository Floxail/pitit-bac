# {hostname} is replaced at runtime by the domain the game is served from,
# so this works unchanged on any domain (nginx proxies /ws to the backend).
VUE_APP_WS_URL=wss://{hostname}/ws

# Public URL of the game, used for social media preview images (og:image).
# Replace with your own domain before building for production.
VUE_APP_URL=https://your-domain.example
